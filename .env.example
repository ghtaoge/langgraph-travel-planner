# ── LLM (必填, 选择其一) ──
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your-api-key-here

# ── PostgreSQL ──
POSTGRES_URI=postgresql://postgres:123456@172.16.28.172:5432/WxMajor
POSTGRES_PASSWORD=123456

# ── JWT Auth ──
JWT_SECRET_KEY=change-me-in-production-use-a-random-string
JWT_EXPIRE_HOURS=24

# ── LangSmith (可选) ──
LANGSMITH_API_KEY=your-langsmith-key-here
LANGSMITH_PROJECT=langgraph-travel-planner
LANGCHAIN_TRACING_V2=true

# ── Server ──
HOST=0.0.0.0
PORT=8000

# ── Frontend ──
VITE_API_URL=http://localhost:8000
