# ── LLM (必填, 选择其一) ──
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your-api-key-here

# ── PostgreSQL ──
# 本地开发用 docker-compose 自建 PG (默认值):
POSTGRES_URI=postgresql://travel_user:travel_pass_2026@localhost:5432/travel_planner
POSTGRES_PASSWORD=travel_pass_2026
# 如果使用外部 PG, 修改为你的连接串, 例如:
# POSTGRES_URI=postgresql://postgres:yourpassword@your-host:5432/your_database

# ── JWT Auth ──
JWT_SECRET_KEY=change-me-in-production-use-a-random-string
JWT_EXPIRE_HOURS=24

# ── LangSmith (可选) ──
LANGSMITH_API_KEY=your-langsmith-key-here
LANGSMITH_PROJECT=langgraph-travel-planner
LANGCHAIN_TRACING_V2=true

# ── Server ──
HOST=0.0.0.0
PORT=8000

# ── Frontend ──
VITE_API_URL=http://localhost:8000
